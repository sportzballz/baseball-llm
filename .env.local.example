# Copy this file to .env.local and fill values.
# These are read by cron/run-local.sh before launching the model.

# Which model to run (ashburn | bowa | carlton | dutch | ennis)
MODEL=dutch

# Optional: pin Python binary. If unset, wrapper uses .venv/bin/python then python3.
# PYTHON_BIN=/Users/asmith/.openclaw/workspace/baseball/.venv/bin/python

# Required API keys/tokens used by connectors
SPORTSPAGE_API_KEY=your_sportspage_api_key
SLACK_TOKEN=xoxb-...
SPORTZBALLZ_SLACK_TOKEN=xoxb-...
OPENAI_API_KEY=sk-...
